# Backend environment variables for MathVerse
# Copy this file to .env and fill in the required values.

GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_LIVE_VOICE=Sulafat
GEMINI_LIVE_INPUT_LANGUAGE=en-IN
GEMINI_LIVE_OUTPUT_LANGUAGE=en-IN
MATHVERSE_RELOAD=false
MATHVERSE_ENABLE_FIREBASE=true
GOOGLE_CLOUD_PROJECT=matverse
GOOGLE_CLOUD_QUOTA_PROJECT=matverse
GOOGLE_CLOUD_LOCATION=us-central1
FIRESTORE_PROJECT_ID=matverse
MATHVERSE_FIRESTORE_AUTH_MODE=adc
MATHVERSE_REQUIRED_GCLOUD_ACCOUNT=miteshc527@gmail.com
FIREBASE_SERVICE_ACCOUNT_PATH=
MATHVERSE_RAG_COLLECTION=pdf_chunks
MATHVERSE_CURRICULUM_SOURCE=local
MATHVERSE_EXERCISES_SOURCE=firestore
MATHVERSE_EXERCISES_ALLOW_LOCAL_FALLBACK=true
MATHVERSE_LOCAL_PDF_ROOT=offline_assets/pdfs
MATHVERSE_CACHE_BACKEND=memory
MATHVERSE_CACHE_TTL_SECONDS=86400
MATHVERSE_RAG_CACHE_TTL_SECONDS=3600
ORCHESTRATOR_STORE=memory
MATHVERSE_ENABLE_TTS=false
LIVEAVATAR_API_BASE=https://api.liveavatar.com
LIVEAVATAR_EMBED_BASE=https://meet.livekit.io/custom
LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_VOICE_ID=
LIVEAVATAR_LANGUAGE=en
LIVEAVATAR_MODE=FULL
LIVEAVATAR_IS_SANDBOX=true
LIVEAVATAR_AUTO_START=false
LIVEAVATAR_SPEECH_SPEED=0.78
