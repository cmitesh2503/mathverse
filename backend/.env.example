# ==========================================================
# MathVerse
# ==========================================================

APP_NAME=MathVerse
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# ==========================================================
# Google Cloud
# ==========================================================

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_QUOTA_PROJECT=your-project-id

# ==========================================================
# Firestore
# ==========================================================

FIRESTORE_PROJECT_ID=your-project-id
MATHVERSE_FIRESTORE_AUTH_MODE=adc

# Optional
MATHVERSE_REQUIRED_GCLOUD_ACCOUNT=

# ==========================================================
# Vertex AI
# ==========================================================

VERTEX_TEXT_MODEL=gemini-2.5-flash
VERTEX_LIVE_MODEL=gemini-2.5-flash

VERTEX_INPUT_LANGUAGE=en-IN
VERTEX_OUTPUT_LANGUAGE=en-IN
VERTEX_VOICE=Sulafat

# ==========================================================
# Backward Compatibility
# ==========================================================

GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash

GEMINI_LIVE_INPUT_LANGUAGE=en-IN
GEMINI_LIVE_OUTPUT_LANGUAGE=en-IN
GEMINI_LIVE_VOICE=Sulafat

# ==========================================================
# API Keys
# ==========================================================

GEMINI_API_KEY=
GOOGLE_API_KEY=

# ==========================================================
# LiveAvatar
# ==========================================================

LIVEAVATAR_API_BASE=https://api.liveavatar.com
LIVEAVATAR_EMBED_BASE=https://embed.liveavatar.com

LIVEAVATAR_API_KEY=
LIVEAVATAR_AVATAR_ID=
LIVEAVATAR_CONTEXT_ID=
LIVEAVATAR_VOICE_ID=

LIVEAVATAR_LANGUAGE=en
LIVEAVATAR_MODE=FULL
LIVEAVATAR_IS_SANDBOX=true
LIVEAVATAR_AUTO_START=true
LIVEAVATAR_SPEECH_SPEED=0.65

# ==========================================================
# Knowledge Factory
# ==========================================================

MATHVERSE_CURRICULUM_SOURCE=local
MATHVERSE_EXERCISES_SOURCE=firestore

# ==========================================================
# Retrieval (RAG)
# ==========================================================

MATHVERSE_RAG_COLLECTION=pdf_chunks
MATHVERSE_RAG_CACHE_TTL_SECONDS=3600

# ==========================================================
# Cache
# ==========================================================

MATHVERSE_CACHE_BACKEND=memory
MATHVERSE_CACHE_TTL_SECONDS=86400

# ==========================================================
# Tutor
# ==========================================================

ORCHESTRATOR_STORE=memory
MATHVERSE_ENABLE_TTS=false
MATHVERSE_ENABLE_FIREBASE=true

# ==========================================================
# Offline Assets
# ==========================================================

MATHVERSE_LOCAL_PDF_ROOT=offline_assets/pdfs
MATHVERSE_EXERCISES_ALLOW_LOCAL_FALLBACK=false

ORCHESTRATOR_STORE=memory
ORCHESTRATOR_SESSION_KEY_PREFIX=orchestrator:session:
MATHVERSE_ENABLE_ATTEMPT_LOGGING=false